{
  "name": "knockout-or-not",
  "private": true,
  "version": "1.0.0",
  "description": "Spoiler-free UFC fight watchability guide",
  "type": "module",
  "workspaces": [
    "shared",
    "pipeline",
    "web"
  ],
  "scripts": {
    "data:refresh": "npm -w pipeline run refresh",
    "data:backfill": "npm -w pipeline run refresh -- --backfill-bonuses",
    "audit": "npm -w pipeline run audit",
    "dev": "npm -w web run dev",
    "build": "npm -w web run build",
    "preview": "npm -w web run preview",
    "typecheck": "npm -w shared run typecheck && npm -w pipeline run typecheck && npm -w web run typecheck",
    "test": "npm -w pipeline run test && npm -w web run test",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
